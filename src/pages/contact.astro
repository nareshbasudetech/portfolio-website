---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE, CONTACT } from '~/consts';

const yes = [
  'Full-stack web apps and marketing sites (Next, Astro, React)',
  'Brand identity paired with the site that ships it',
  'Technical SEO, GEO, and growth marketing',
  'Product launches with measurement wired in',
  'Retained partnerships (3 — 12 months)',
];

const no = [
  'Logo-only one-offs without strategy or context',
  'Animation-only or visual-effects-only briefs',
  'Crypto, casino, or scraping projects',
  'Lowest-bid procurement work',
];

const faqs = [
  { q: 'How do you charge?', a: 'No public rate card — pricing depends on scope and we discuss it in the brief. Project-based for fixed-scope work, weekly retainer for ongoing partnerships. Either way you get a clear deliverable per cycle.' },
  { q: 'How fast can you start?', a: 'Discovery the day the brief lands. Projects delivered within 7 days — live URL, instrumentation in place, SEO and lifecycle wired up. Larger products iterate from there.' },
  { q: 'Do you work with teams?', a: 'Yes. I work solo for the heavy lifting, and I plug into existing teams when a designer, engineer, or marketer is already in place.' },
  { q: 'Where are you based?', a: 'India. I work async with clients across UTC-8 to UTC+10 and overlap two time zones live each day.' },
];
---

<BaseLayout
  title="Contact — Website Developer in Thane"
  description={`Contact ${SITE.name} — website & app developer in Thane covering MMR. WhatsApp, email, phone. ${SITE.availability}. Reply within 24 hours.`}
  schemaType="home"
  breadcrumbs={[
    { name: 'Home', item: '/' },
    { name: 'Contact', item: '/contact' },
  ]}
  faqs={faqs.map((f) => ({ q: f.q, a: f.a }))}
>
  <!-- HEAD -->
  <section class="shell hd">
    <h1 class="sr-only">Contact Naresh Basude — Website &amp; App Developer in Thane</h1>

    <div class="hd__brackets" aria-hidden="true">
      <span>[ CONTACT ]</span>
      <span>{SITE.availability}</span>
      <span>REPLIES &lt; 24H</span>
    </div>

    <a href={`mailto:${SITE.email}`} class="big">
      Let's make it<br /><em>move.</em><span class="arr" aria-hidden="true"> ↗</span>
    </a>

    <p class="t-lede big__sub">
      Got a project? One message is enough.
      <a href={`mailto:${SITE.email}`} class="email">{SITE.email}</a> —
      replies within 24 hours.
    </p>

    <div class="channels" aria-label="Contact channels">
      <a href={`mailto:${SITE.email}`} class="ch">
        <span class="ch__lbl">Email</span>
        <span class="ch__val">{SITE.email}</span>
      </a>
      <a href={`https://wa.me/${CONTACT.whatsapp}`} class="ch ch--wa" target="_blank" rel="noopener">
        <span class="ch__lbl">WhatsApp</span>
        <span class="ch__val">{CONTACT.phoneDisplay} ↗</span>
      </a>
      <a href={`tel:${CONTACT.phone}`} class="ch">
        <span class="ch__lbl">Phone</span>
        <span class="ch__val">{CONTACT.phoneDisplay}</span>
      </a>
      {CONTACT.linkedin && (
        <a href={CONTACT.linkedin} class="ch" target="_blank" rel="noopener">
          <span class="ch__lbl">LinkedIn</span>
          <span class="ch__val">Open profile ↗</span>
        </a>
      )}
    </div>

    <address class="nap">
      <span class="nap__lbl t-mono-sm">Based in</span>
      <span class="nap__val">Thane, Maharashtra 400601, India</span>
      <span class="nap__lbl t-mono-sm">Hours</span>
      <span class="nap__val">Mon — Sat · 9:00 AM — 8:00 PM IST</span>
      <span class="nap__lbl t-mono-sm">Serving</span>
      <span class="nap__val">Thane · Mumbai · Navi Mumbai · Kalyan-Bhiwandi · Dombivli · Mira-Bhayandar · Vasai-Virar · Panvel · India · Remote worldwide</span>
    </address>
  </section>

  <!-- AVAILABILITY -->
  <section class="shell sec">
    <header class="sec-head">
      <span class="sec-head__num"><b>01</b> &nbsp;/&nbsp; Availability</span>
      <span class="sec-head__lab">Live · taking briefs</span>
    </header>

    <div class="avail">
      <div class="avail__signal" aria-hidden="true">
        <span class="dot dot--orange"></span>
        <span class="dot dot--orange dot--ghost"></span>
        <span class="dot dot--orange dot--ghost-2"></span>
      </div>
      <div class="avail__body">
        <h2 class="avail__title">Available <em>now</em>.</h2>
        <p class="t-lede">
          Currently accepting new briefs. <b>Projects delivered within 7 days</b> —
          live URL, instrumentation in place, SEO and lifecycle wired up.
          Larger builds iterate from there. Replies within 24 hours, every time.
        </p>
        <div class="avail__row">
          <a href={`mailto:${SITE.email}`} class="btn">
            Send a brief <span class="arr" aria-hidden="true">→</span>
          </a>
          <a href={`https://wa.me/${CONTACT.whatsapp}`} class="btn btn--ghost" target="_blank" rel="noopener">
            WhatsApp ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- WORK / NO -->
  <section class="shell sec">
    <header class="sec-head">
      <span class="sec-head__num"><b>02</b> &nbsp;/&nbsp; Fit check</span>
      <span class="sec-head__lab">What I take · what I skip</span>
    </header>

    <div class="fit">
      <div class="fit__col fit__yes">
        <h3 class="t-h3">Yes — let's talk</h3>
        <ul>
          {yes.map((y) => <li>{y}</li>)}
        </ul>
      </div>
      <div class="fit__col fit__no">
        <h3 class="t-h3">No — not a fit</h3>
        <ul>
          {no.map((n) => <li>{n}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="shell sec">
    <header class="sec-head">
      <span class="sec-head__num"><b>03</b> &nbsp;/&nbsp; FAQ</span>
      <span class="sec-head__lab">The usual asks</span>
    </header>

    <ul class="faq" role="list">
      {faqs.map(({ q, a }, i) => (
        <li class="faq__item">
          <details>
            <summary>
              <span class="faq__n">{String(i + 1).padStart(2, '0')}</span>
              <span class="faq__q">{q}</span>
              <span class="faq__plus" aria-hidden="true">+</span>
            </summary>
            <p>{a}</p>
          </details>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .hd { padding-block: clamp(3rem, 8vh, 6rem) clamp(3rem, 6vh, 5rem); }
  .hd__brackets {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 2rem;
  }
  .big {
    font-family: var(--font-display);
    font-size: clamp(3rem, 13vw, 13rem);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.04em;
    display: inline-block;
    transition: color 250ms;
  }
  .big em {
    font-style: italic;
    color: var(--color-orange);
    font-family: var(--font-display);
  }
  .big .arr { display: inline-block; transition: transform 250ms; }
  .big:hover { color: var(--color-orange); }
  .big:hover .arr { transform: translate(0.3rem, -0.3rem); }

  .big__sub {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--grid-line);
  }
  .email {
    color: var(--color-orange);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .channels {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.5rem;
  }
  .ch {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--grid-line);
    border-radius: var(--radius-md);
    background: var(--color-ink-2);
    transition: border-color 220ms, transform 280ms var(--ease-out-expo);
  }
  .ch:hover { border-color: var(--color-orange); transform: translateY(-2px); }
  .ch--wa:hover { border-color: #25d366; }
  .ch__lbl {
    font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--color-mute);
  }
  .ch__val { font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: var(--color-ivory); }

  .nap {
    margin-top: 1.25rem;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.6rem 1.5rem;
    align-items: baseline;
    padding: 1rem 1.25rem;
    border: 1px solid var(--grid-line);
    border-radius: var(--radius-md);
    background: var(--color-ink-2);
    font-style: normal;
  }
  .nap__lbl { color: var(--color-mute); }
  .nap__val { color: var(--color-ivory); font-family: var(--font-sans); font-size: 0.92rem; }
  @media (max-width: 720px) {
    .nap { grid-template-columns: 1fr; gap: 0.3rem; }
    .nap__lbl { margin-top: 0.6rem; }
    .nap__lbl:first-child { margin-top: 0; }
  }

  .sec { padding-block: clamp(3rem, 7vh, 5rem); }

  /* AVAILABILITY */
  .avail {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 2rem;
    align-items: start;
    padding: 2.5rem 2rem;
    border: 1px solid var(--color-orange);
    border-radius: var(--radius-md);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--color-orange) 8%, transparent), transparent 60%),
      var(--color-ink-2);
    box-shadow: 0 18px 60px color-mix(in oklab, var(--color-orange) 14%, transparent);
  }
  .avail__signal {
    position: relative;
    width: 80px;
    height: 80px;
    display: grid;
    place-items: center;
  }
  .avail__signal .dot {
    position: absolute;
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: var(--color-orange);
    box-shadow: 0 0 24px var(--color-orange);
    animation: avail-pulse 2.4s ease-out infinite;
  }
  .avail__signal .dot--ghost {
    width: 36px; height: 36px;
    background: transparent;
    border: 1px solid color-mix(in oklab, var(--color-orange) 60%, transparent);
    box-shadow: none;
    animation-delay: 0.4s;
    opacity: 0;
  }
  .avail__signal .dot--ghost-2 {
    width: 64px; height: 64px;
    animation-delay: 0.8s;
  }
  @keyframes avail-pulse {
    0% { transform: scale(0.8); opacity: 1; }
    70% { transform: scale(1.2); opacity: 0.4; }
    100% { transform: scale(1.4); opacity: 0; }
  }
  .avail__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    color: var(--color-ivory);
  }
  .avail__title em { color: var(--color-orange); font-style: italic; }
  .avail__body { display: flex; flex-direction: column; gap: 1rem; }
  .avail__row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1rem; }

  .dot--orange { background: var(--color-orange); }
  .dot--violet { background: var(--color-violet); }
  .dot--mute { background: var(--color-mute); }

  @media (max-width: 720px) {
    .avail { grid-template-columns: 1fr; padding: 2rem 1.5rem; gap: 1.5rem; }
    .avail__signal { width: 64px; height: 64px; }
  }

  /* FIT */
  .fit { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .fit__col {
    padding: 2rem 1.75rem;
    border: 1px solid var(--grid-line);
    border-radius: var(--radius-md);
    background: var(--color-ink-2);
  }
  .fit__yes { border-color: color-mix(in oklab, var(--color-orange) 30%, var(--grid-line)); }
  .fit__yes h3 { color: var(--color-orange); }
  .fit__no h3 { color: var(--color-mute); }
  .fit__col h3 { margin-bottom: 1.5rem; }
  .fit__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    color: var(--color-ivory-dim);
    line-height: 1.5;
  }
  .fit__yes li::before { content: '✓ '; color: var(--color-orange); }
  .fit__no li::before { content: '— '; color: var(--color-mute); }

  /* FAQ */
  .faq { list-style: none; padding: 0; margin: 0; }
  .faq__item { border-top: 1px solid var(--grid-line); }
  .faq__item:last-child { border-bottom: 1px solid var(--grid-line); }
  .faq details {
    padding: 1.5rem 0;
  }
  .faq summary {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: 50px 1fr auto;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    letter-spacing: -0.015em;
  }
  .faq summary::-webkit-details-marker { display: none; }
  .faq__n { font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-orange); }
  .faq__plus {
    font-family: var(--font-mono);
    font-size: 1.4rem;
    transition: transform 250ms var(--ease-out-expo);
    color: var(--color-orange);
  }
  details[open] .faq__plus { transform: rotate(45deg); }
  .faq details p {
    margin: 1rem 0 0;
    padding-left: 4rem;
    color: var(--color-ivory-dim);
    line-height: 1.6;
    max-width: 60ch;
  }

  @media (max-width: 820px) {
    .fit { grid-template-columns: 1fr; }
    .faq summary { grid-template-columns: 36px 1fr auto; }
    .faq details p { padding-left: 0; }
  }
</style>
