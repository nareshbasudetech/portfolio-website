---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '~/consts';

const principles = [
  { n: '01', t: 'One brain, one timeline.', b: 'No handoffs between code, design, and growth — they ship as one piece, on one calendar.' },
  { n: '02', t: 'Pick the number first.', b: 'Every project starts with the metric we will move. Everything afterward serves it.' },
  { n: '03', t: 'Ship every week.', b: 'No "it will be ready next month." Real product, deployed, every week — even when it is rough.' },
  { n: '04', t: 'Performance is design.', b: 'A four-second LCP is a UX problem before it is a tech problem. Speed is part of the brand.' },
  { n: '05', t: 'Measure, then iterate.', b: 'Server-side analytics from day one. We don\'t guess what worked — we read it.' },
];

const stack = [
  { kind: 'Frontend', items: ['Next.js', 'Astro', 'React', 'TypeScript', 'Tailwind v4', 'Framer Motion', 'GSAP'] },
  { kind: 'Backend', items: ['Node.js', 'Express', 'Hono', 'Edge runtimes', 'tRPC', 'REST'] },
  { kind: 'Data', items: ['Postgres', 'Supabase', 'Redis', 'D1 / KV', 'Prisma'] },
  { kind: 'Design', items: ['Figma', 'Illustrator', 'Photoshop', 'After Effects', 'Tokens Studio'] },
  { kind: 'Growth', items: ['GA4', 'Meta CAPI', 'GSC', 'Klaviyo', 'PostHog', 'Looker Studio'] },
  { kind: 'Infra', items: ['Cloudflare', 'Vercel', 'Netlify', 'GitHub Actions', 'Docker'] },
];

const now = [
  'Running performance marketing across 20+ brands — education, real estate, e-commerce, healthcare, B2B',
  'Shipping Naresh-CRM — multi-platform lead management with role-based hierarchy',
  'Iterating the WhatsApp lead bot with new flows for partner clients',
  'Studying generative engine optimization (GEO) for AI-search citation across Perplexity, ChatGPT, and AI Overviews',
];
---

<BaseLayout
  title="About — Developer, Marketer & Designer in Thane"
  description="Naresh Basude — full-stack developer, growth marketer, and designer in Thane. One brain across dev, design, and marketing. Seven years shipping for SMBs and startups."
  schemaType="about"
  breadcrumbs={[
    { name: 'Home', item: '/' },
    { name: 'About', item: '/about' },
  ]}
>
  <!-- HEAD -->
  <section class="shell hd">
    <div class="hd__brackets">
      <span>[ ABOUT ]</span>
      <span>NARESH · BASUDE</span>
      <span>EST · 2019</span>
    </div>
    <h1 class="t-display">
      One brain. <em>Three disciplines.</em>
    </h1>
  </section>

  <!-- INTRO -->
  <section class="shell sec intro">
    <p class="lede">
      Most sites fail the moment they change hands. <em>I don't hand anything off.</em>
      I market the thing, I design the thing, and I build the thing — so the work
      ships with one voice, on one timeline, measured against one number.
    </p>
    <p class="t-lede intro__where">
      Based in <strong>Thane, Maharashtra</strong> — working with clients in
      Bhiwandi, Mumbai, Navi Mumbai, and remote-first across India and worldwide.
    </p>
    <div class="intro__by">
      <span class="t-mono-sm">— {SITE.name}</span>
      <span class="t-mono-sm">Thane · MH · IN · 2026</span>
    </div>
  </section>

  <!-- WHAT I DELIVER -->
  <section class="shell sec">
    <header class="sec-head">
      <span class="sec-head__num"><b>01</b> &nbsp;/&nbsp; What I deliver</span>
      <span class="sec-head__lab">End-to-end · One brain</span>
    </header>
    <ul class="deliver" role="list">
      <li><b>Apps</b><span>Mobile-first web apps and PWAs — student platforms, study companions, lead products.</span></li>
      <li><b>Websites</b><span>Marketing sites, brand sites, admissions funnels, e-commerce — editable by your team without engineering.</span></li>
      <li><b>Web apps</b><span>Internal tools, dashboards, CRMs, ERPs — multi-role workflows with admin layers your team owns.</span></li>
      <li><b>Automations</b><span>WhatsApp bots, lead pipelines, scrapers, n8n / Make workflows — boring repetitive work, automated.</span></li>
    </ul>
  </section>

  <!-- PRINCIPLES -->
  <section class="shell sec">
    <header class="sec-head">
      <span class="sec-head__num"><b>02</b> &nbsp;/&nbsp; Principles</span>
      <span class="sec-head__lab">How I work</span>
    </header>
    <ol class="prin" role="list">
      {principles.map(({ n, t, b }) => (
        <li class="prin__row">
          <span class="prin__n">{n}</span>
          <span class="prin__t">{t}</span>
          <span class="prin__b">{b}</span>
        </li>
      ))}
    </ol>
  </section>

  <!-- STACK -->
  <section class="shell sec">
    <header class="sec-head">
      <span class="sec-head__num"><b>03</b> &nbsp;/&nbsp; Toolkit</span>
      <span class="sec-head__lab">Stack · Tools · Infra</span>
    </header>

    <div class="stack">
      {stack.map(({ kind, items }) => (
        <div class="stack__col">
          <h3 class="t-mono-sm">{kind}</h3>
          <ul>
            {items.map((it) => <li>{it}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- NOW -->
  <section class="shell sec">
    <header class="sec-head">
      <span class="sec-head__num"><b>04</b> &nbsp;/&nbsp; Now</span>
      <span class="sec-head__lab">May 2026</span>
    </header>
    <div class="now">
      <p class="t-lede">Currently, in no particular order:</p>
      <ul class="now__list">
        {now.map((n, i) => (
          <li>
            <span class="now__n">{String(i + 1).padStart(2, '0')}</span>
            <span>{n}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .hd { padding-block: clamp(3rem, 8vh, 6rem) clamp(2rem, 5vh, 4rem); }
  .hd__brackets {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 2rem;
  }
  .t-display em {
    color: var(--color-orange);
    font-style: italic;
  }

  .sec { padding-block: clamp(3rem, 7vh, 5rem); }

  .intro { padding-block: clamp(2rem, 4vh, 3rem) clamp(3rem, 6vh, 5rem); }
  .lede {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.6vw, 2.2rem);
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.02em;
    max-width: 32ch;
    color: var(--color-ivory);
  }
  .lede em { color: var(--color-orange); font-style: italic; }
  .intro__where {
    margin-top: 1.5rem;
    max-width: 50ch;
    color: var(--color-ivory-dim);
  }
  .intro__where strong { color: var(--color-orange); font-weight: 500; }
  .intro__by {
    margin-top: 2rem;
    display: flex;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid var(--grid-line);
    max-width: 36ch;
  }

  .nums {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--grid-line);
    border-radius: var(--radius-md);
    background: var(--color-ink-2);
    overflow: hidden;
  }

  /* Deliver list */
  .deliver {
    list-style: none;
    padding: 0;
    margin: 0;
    border: 1px solid var(--grid-line);
    border-radius: var(--radius-md);
    background: var(--color-ink-2);
    overflow: hidden;
  }
  .deliver li {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    padding: 1.5rem 1.75rem;
    border-bottom: 1px solid var(--grid-line);
    align-items: baseline;
  }
  .deliver li:last-child { border-bottom: 0; }
  .deliver b {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-orange);
    letter-spacing: -0.01em;
  }
  .deliver span { color: var(--color-ivory-dim); line-height: 1.55; }
  @media (max-width: 720px) {
    .deliver li { grid-template-columns: 1fr; gap: 0.5rem; }
  }

  /* PRINCIPLES */
  .prin { list-style: none; padding: 0; margin: 0; }
  .prin__row {
    display: grid;
    grid-template-columns: 60px minmax(0, 0.8fr) minmax(0, 1.2fr);
    align-items: baseline;
    gap: 1.5rem;
    padding: 1.6rem 0;
    border-top: 1px solid var(--grid-line);
  }
  .prin li:last-child .prin__row, .prin__row:last-child {
    border-bottom: 1px solid var(--grid-line);
  }
  .prin__n {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-orange);
    letter-spacing: 0.12em;
  }
  .prin__t {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2vw, 1.6rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.015em;
  }
  .prin__b {
    color: var(--color-ivory-dim);
    line-height: 1.55;
    font-size: 0.95rem;
  }
  @media (max-width: 820px) {
    .prin__row { grid-template-columns: 36px 1fr; }
    .prin__b { grid-column: 2; }
  }

  /* STACK */
  .stack {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .stack__col {
    padding: 1.5rem;
    border: 1px solid var(--grid-line);
    border-radius: var(--radius-md);
    background: var(--color-ink-2);
  }
  .stack__col h3 {
    color: var(--color-orange);
    margin-bottom: 1rem;
  }
  .stack__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    color: var(--color-ivory-dim);
    font-size: 0.93rem;
  }
  .stack__col li::before { content: '— '; color: var(--color-mute); }

  @media (max-width: 820px) {
    .stack { grid-template-columns: 1fr; }
  }

  /* NOW */
  .now { display: grid; grid-template-columns: 240px 1fr; gap: 3rem; align-items: start; }
  .now__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .now__list li {
    display: flex;
    gap: 1.5rem;
    align-items: baseline;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--grid-line);
    color: var(--color-ivory);
    font-size: 1.05rem;
  }
  .now__n {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-orange);
    letter-spacing: 0.1em;
  }
  @media (max-width: 820px) {
    .now { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
