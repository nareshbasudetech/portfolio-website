---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { SITE, CONTACT } from '~/consts';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((p) => ({
    params: { slug: p.id },
    props: { project: p, all: projects },
  }));
}

const { project, all } = Astro.props;
const { Content } = await render(project);

const sorted = [...all].sort((a, b) => b.data.year - a.data.year);
const idx = sorted.findIndex((p) => p.id === project.id);
const prev = sorted[(idx - 1 + sorted.length) % sorted.length];
const next = sorted[(idx + 1) % sorted.length];

const liveLinks = project.data.links?.length
  ? project.data.links
  : project.data.url
    ? [{ label: 'Visit live ↗', href: project.data.url }]
    : [];
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  type="article"
  schemaType="project"
  publishedAt={project.data.publishedAt}
  updatedAt={project.data.updatedAt}
  project={{
    name: project.data.title,
    description: project.data.summary,
    url: project.data.url,
    canonicalUrl: `/projects/${project.id}`,
    year: project.data.year,
    image: project.data.cover,
  }}
  breadcrumbs={[
    { name: 'Home', item: '/' },
    { name: 'Projects', item: '/projects' },
    { name: project.data.title, item: `/projects/${project.id}` },
  ]}
>
  <article class="proj" style={`--ac:${project.data.accent}`}>
    <!-- COVER -->
    <header class="cover shell">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/projects">Projects</a>
        <span>/</span>
        <span class="cur">{project.id}</span>
      </nav>

      <div class="cover__brackets">
        <span>[ {String(idx + 1).padStart(3, '0')} / {String(sorted.length).padStart(3, '0')} ]</span>
        <span>{project.data.discipline.join(' · ')}</span>
        <span>{project.data.year}</span>
      </div>

      <h1 class="t-display cover__title">{project.data.title}</h1>

      <p class="t-lede cover__sum">{project.data.summary}</p>

      {liveLinks.length > 0 && (
        <div class="cover__links" aria-label="Live website links">
          {liveLinks.map((l) => (
            <a href={l.href} class="ext" rel="noopener" target="_blank">
              {l.label}
            </a>
          ))}
        </div>
      )}

      <div class="cover__art">
        <img class="cover__img" src={project.data.cover ?? `/covers/${project.id}.svg`} alt="" loading="eager" decoding="async" />
        {liveLinks.length > 0 && (
          <div class="cover__chips" aria-hidden="true">
            {liveLinks.map((l) => (
              <a href={l.href} class="chip" rel="noopener" target="_blank">
                <span>{l.label.replace(' ↗', '')}</span>
                <span class="chip__icon">↗</span>
              </a>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- BODY -->
    <div class="body shell">
      <aside class="rail">
        <dl class="meta">
          <div>
            <dt>Year</dt>
            <dd>{project.data.year}</dd>
          </div>
          <div>
            <dt>Role</dt>
            <dd>{project.data.role}</dd>
          </div>
          <div>
            <dt>Discipline</dt>
            <dd>{project.data.discipline.join(', ')}</dd>
          </div>
          {project.data.client && (
            <div>
              <dt>Client</dt>
              <dd>{project.data.client}</dd>
            </div>
          )}
          {liveLinks.length > 0 && (
            <div>
              <dt>{liveLinks.length === 1 ? 'Link' : 'Links'}</dt>
              <dd>
                {liveLinks.map((l, i) => (
                  <Fragment>
                    {i > 0 && <br />}
                    <a href={l.href} rel="noopener" target="_blank">{l.label}</a>
                  </Fragment>
                ))}
              </dd>
            </div>
          )}
        </dl>

        {liveLinks.length > 0 && (
          <div class="rail__ctas">
            {liveLinks.map((l) => (
              <a href={l.href} class="rail__cta" rel="noopener" target="_blank">
                {l.label.replace(' ↗', '')} <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        )}
      </aside>

      <div class="prose">
        <Content />
      </div>
    </div>

    <aside class="hire shell" aria-label="Hire Naresh">
      <div class="hire__inner">
        <div class="hire__copy">
          <span class="t-mono-sm hire__lab">Like the work?</span>
          <h2 class="t-h2 hire__h">Hire me for the same on your project.</h2>
          <p class="hire__p">
            Website, app, WhatsApp bot, growth marketing — one brain across
            the whole funnel. Replies inside 24 hours.
            <strong>{SITE.availability}.</strong>
          </p>
        </div>
        <div class="hire__cta">
          <a href={`https://wa.me/${CONTACT.whatsapp}`} target="_blank" rel="noopener" class="hire__btn">WhatsApp me <span aria-hidden="true">↗</span></a>
          <a href={`mailto:${SITE.email}`} class="hire__btn hire__btn--ghost">Send a brief</a>
        </div>
      </div>
    </aside>

    {project.data.demos && project.data.demos.length > 0 && (
      <section class="demos shell">
        <header class="demos__head">
          <span class="t-mono-sm">Live demos</span>
          <h2 class="t-h2">{project.data.demos.length} templates · click any to open</h2>
        </header>
        <ul class="demos__grid" role="list">
          {project.data.demos.map((d) => (
            <li>
              <a class="demo" href={d.href} target="_blank" rel="noopener">
                <div class="demo__viz">
                  <img src={d.thumb} alt={d.title} loading="lazy" decoding="async" />
                  <span class="demo__chip">View live ↗</span>
                </div>
                <div class="demo__meta">
                  <span class="demo__industry">{d.industry}</span>
                  <span class="demo__title">{d.title}</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- PAGER -->
    <footer class="pager shell">
      <a href={`/projects/${prev.id}`} class="pager__a">
        <span class="t-mono-sm">← Previous</span>
        <span class="pager__name">{prev.data.title}</span>
      </a>
      <a href="/projects" class="pager__home">
        <span class="t-mono-sm">All projects</span>
        <span class="pager__name">View archive ↗</span>
      </a>
      <a href={`/projects/${next.id}`} class="pager__a pager__a--r">
        <span class="t-mono-sm">Next →</span>
        <span class="pager__name">{next.data.title}</span>
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .proj { padding-block: clamp(3rem, 8vh, 6rem) 0; }

  /* COVER */
  .cover {
    padding-bottom: clamp(3rem, 6vh, 5rem);
    border-bottom: 1px solid var(--grid-line);
  }
  .crumbs {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 2.5rem;
  }
  .crumbs a:hover { color: var(--ac); }
  .cur { color: var(--ac); }

  .cover__brackets {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.6;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--grid-line);
    margin-bottom: 2rem;
  }
  .cover__title {
    max-width: 18ch;
    margin-bottom: 2rem;
  }
  .cover__sum { margin-bottom: 3rem; }

  .cover__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }
  .cover__links .ext {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1rem;
    border: 1px solid var(--ac);
    color: var(--ac);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 200ms, color 200ms;
    margin-top: 0;
  }
  .cover__links .ext:hover { background: var(--ac); color: var(--color-ink); }

  .cover__art {
    position: relative;
    aspect-ratio: 3 / 2;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-ink-3);
    border: 1px solid var(--grid-line);
  }
  .cover__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cover__chips {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    display: flex;
    flex-wrap: wrap-reverse;
    gap: 0.4rem;
    justify-content: flex-end;
    pointer-events: none;
    max-width: calc(100% - 2rem);
  }
  .cover__chips .chip {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.85rem;
    background: color-mix(in oklab, var(--color-ink) 80%, transparent);
    backdrop-filter: blur(10px);
    border: 1px solid color-mix(in oklab, var(--color-ivory) 20%, transparent);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ivory);
    transition: background 200ms, color 200ms, border-color 200ms;
    text-decoration: none;
  }
  .cover__chips .chip:hover {
    background: var(--ac);
    color: var(--color-ink);
    border-color: var(--ac);
  }
  .chip__icon { font-size: 0.85rem; }

  .rail__ctas { display: flex; flex-direction: column; gap: 0.5rem; }

  /* BODY */
  .body {
    padding-block: clamp(3rem, 8vh, 6rem);
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 3rem;
  }

  .rail {
    position: sticky;
    top: 6rem;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .meta {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid var(--grid-line);
    border-radius: var(--radius-md);
    background: var(--color-ink-2);
  }
  .meta > div { display: flex; flex-direction: column; gap: 0.3rem; }
  .meta dt {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-mute);
    margin: 0;
  }
  .meta dd {
    margin: 0;
    font-size: 0.92rem;
    color: var(--color-ivory);
  }
  .meta a:hover { color: var(--ac); }
  .rail__cta {
    display: inline-flex;
    justify-content: center;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    border: 1px solid var(--ac);
    color: var(--ac);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 200ms, color 200ms;
  }
  .rail__cta:hover { background: var(--ac); color: var(--color-ink); }

  /* PROSE */
  .prose { max-width: 64ch; }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 3rem 0 1rem;
    line-height: 1.1;
  }
  .prose :global(h2)::before {
    content: '§ ';
    color: var(--ac);
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.7em;
    letter-spacing: 0.05em;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 2rem 0 0.5rem;
  }
  .prose :global(p) {
    line-height: 1.7;
    font-size: 1.02rem;
    color: var(--color-ivory-dim);
    margin: 1rem 0;
  }
  .prose :global(p:first-of-type)::first-letter {
    font-family: var(--font-display);
    font-size: 3.5em;
    font-weight: 700;
    line-height: 0.9;
    float: left;
    padding: 0.3rem 0.4rem 0 0;
    color: var(--ac);
  }
  .prose :global(ul), .prose :global(ol) {
    line-height: 1.7;
    margin: 1rem 0;
    padding-left: 1.5rem;
    color: var(--color-ivory-dim);
  }
  .prose :global(li) { margin: 0.4rem 0; }
  .prose :global(li::marker) { color: var(--ac); }
  .prose :global(code) {
    font-family: var(--font-mono);
    background: color-mix(in oklab, var(--color-ivory) 8%, transparent);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }
  .prose :global(blockquote) {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--ac);
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1.4;
    color: var(--color-ivory);
  }
  .prose :global(a) {
    color: var(--ac);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(hr) {
    margin: 3rem 0;
    border: 0;
    height: 1px;
    background: var(--grid-line);
  }

  /* HIRE CTA — between body & demos */
  .hire {
    padding-block: clamp(2rem, 5vh, 4rem);
    border-top: 1px solid var(--grid-line);
  }
  .hire__inner {
    display: grid;
    grid-template-columns: 1.4fr auto;
    gap: 2rem;
    align-items: center;
    padding: clamp(1.75rem, 3vw, 2.5rem);
    border: 1px solid var(--ac);
    border-radius: var(--radius-md);
    background: color-mix(in oklab, var(--ac) 6%, transparent);
  }
  .hire__lab {
    display: block;
    color: var(--ac);
    margin-bottom: 0.4rem;
  }
  .hire__h {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0 0 0.75rem;
    color: var(--color-ivory);
  }
  .hire__p {
    color: var(--color-ivory-dim);
    line-height: 1.55;
    max-width: 56ch;
    margin: 0;
  }
  .hire__p strong { color: var(--ac); font-weight: 500; }
  .hire__cta { display: flex; flex-direction: column; gap: 0.5rem; min-width: 200px; }
  .hire__btn {
    display: inline-flex;
    justify-content: center;
    padding: 0.85rem 1.25rem;
    border-radius: 999px;
    background: var(--ac);
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: filter 200ms;
  }
  .hire__btn:hover { filter: brightness(1.1); }
  .hire__btn--ghost {
    background: transparent;
    color: var(--ac);
    border: 1px solid var(--ac);
  }
  .hire__btn--ghost:hover { background: var(--ac); color: var(--color-ink); filter: none; }
  @media (max-width: 720px) {
    .hire__inner { grid-template-columns: 1fr; }
    .hire__cta { min-width: 0; }
  }

  /* DEMOS */
  .demos {
    padding-block: clamp(2rem, 5vh, 4rem);
    border-top: 1px solid var(--grid-line);
  }
  .demos__head {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2.5rem;
  }
  .demos__head h2 {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-ivory);
  }
  .demos__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .demo {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--grid-line);
    border-radius: var(--radius-md);
    background: var(--color-ink-2);
    overflow: hidden;
    transition: border-color 240ms, transform 320ms var(--ease-out-expo);
    text-decoration: none;
  }
  .demo:hover, .demo:focus-visible {
    border-color: var(--ac);
    transform: translateY(-3px);
    outline: none;
  }
  .demo__viz {
    position: relative;
    aspect-ratio: 3 / 2;
    background: var(--color-ink-3);
    overflow: hidden;
  }
  .demo__viz img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform 480ms var(--ease-out-expo);
  }
  .demo:hover .demo__viz img { transform: scale(1.03); }
  .demo__chip {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    padding: 0.4rem 0.8rem;
    background: color-mix(in oklab, var(--color-ink) 80%, transparent);
    backdrop-filter: blur(8px);
    border: 1px solid color-mix(in oklab, var(--color-ivory) 18%, transparent);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ivory);
    transition: background 200ms, color 200ms, border-color 200ms;
  }
  .demo:hover .demo__chip {
    background: var(--ac);
    color: var(--color-ink);
    border-color: var(--ac);
  }
  .demo__meta {
    padding: 1.25rem 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .demo__industry {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-mute);
  }
  .demo__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: -0.015em;
    color: var(--color-ivory);
  }

  /* PAGER */
  .pager {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.5rem;
    padding: 3rem 0;
    border-top: 1px solid var(--grid-line);
    margin-top: 2rem;
  }
  .pager__a {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: color 220ms;
  }
  .pager__a--r { text-align: right; align-items: flex-end; }
  .pager__a:hover { color: var(--ac); }
  .pager__name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
  }
  .pager__home {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.8rem 1.4rem;
    border: 1px solid var(--grid-line);
    border-radius: var(--radius-md);
    transition: border-color 220ms, color 220ms;
  }
  .pager__home:hover { border-color: var(--ac); color: var(--ac); }

  @media (max-width: 900px) {
    .body { grid-template-columns: 1fr; gap: 2rem; }
    .rail { position: static; }
    .pager { grid-template-columns: 1fr; gap: 1rem; }
    .pager__a--r { text-align: left; align-items: flex-start; }
  }
</style>
