---
import { SITE, CONTACT } from '~/consts';
---

<aside class="mcta" aria-label="Quick contact">
  <a href={`tel:${CONTACT.phone}`} class="mcta__btn mcta__btn--call">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
    <span>Call</span>
  </a>

  <a href={`https://wa.me/${CONTACT.whatsapp}`} target="_blank" rel="noopener" class="mcta__btn mcta__btn--wa">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor">
      <path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.88 11.93L4 20l4.18-1.1a7.93 7.93 0 0 0 3.86 1h.01c4.39 0 7.96-3.57 7.96-7.96 0-2.13-.83-4.13-2.41-5.62zm-5.55 12.24h-.01a6.61 6.61 0 0 1-3.36-.92l-.24-.14-2.48.65.66-2.42-.16-.25a6.61 6.61 0 1 1 12.24-3.51 6.61 6.61 0 0 1-6.65 6.59zm3.62-4.94c-.2-.1-1.18-.58-1.36-.65-.18-.07-.31-.1-.45.1-.13.2-.51.65-.62.78-.11.13-.23.15-.42.05-.2-.1-.84-.31-1.6-.99-.59-.53-.99-1.18-1.1-1.38-.11-.2-.01-.31.09-.4.09-.09.2-.23.3-.35.1-.12.13-.2.2-.33.07-.13.03-.25-.02-.35-.05-.1-.45-1.09-.62-1.49-.16-.39-.33-.34-.45-.34h-.38c-.13 0-.35.05-.53.25-.18.2-.69.68-.69 1.65 0 .98.71 1.93.81 2.06.1.13 1.4 2.13 3.39 2.99.47.2.84.32 1.13.41.48.15.91.13 1.25.08.38-.06 1.18-.48 1.34-.95.17-.47.17-.86.12-.95-.05-.09-.18-.14-.38-.24z"/>
    </svg>
    <span>WhatsApp</span>
  </a>

  <a href="/contact" class="mcta__btn mcta__btn--brief">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
      <polyline points="22,6 12,13 2,6"/>
    </svg>
    <span>Brief</span>
  </a>
</aside>

<style>
  .mcta {
    display: none;
  }

  @media (max-width: 720px) {
    .mcta {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 0.5rem;
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 60;
      padding: 0.75rem 0.85rem calc(0.75rem + env(safe-area-inset-bottom));
      background: color-mix(in oklab, var(--color-ink) 85%, transparent);
      backdrop-filter: blur(14px) saturate(160%);
      border-top: 1px solid color-mix(in oklab, var(--color-ivory) 12%, transparent);
      box-shadow: 0 -10px 30px color-mix(in oklab, var(--color-ink) 80%, transparent);
    }
  }

  .mcta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 0.85rem 0.5rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
    text-decoration: none;
    transition: transform 220ms var(--ease-out-expo), opacity 200ms;
    min-height: 44px;
    -webkit-tap-highlight-color: transparent;
  }
  .mcta__btn:active { transform: scale(0.96); }

  .mcta__btn--call {
    background: transparent;
    color: var(--color-ivory);
    border: 1px solid color-mix(in oklab, var(--color-ivory) 25%, transparent);
  }
  .mcta__btn--wa {
    background: #25d366;
    color: #050505;
    border: 1px solid #25d366;
  }
  .mcta__btn--brief {
    background: var(--color-orange);
    color: var(--color-ink);
    border: 1px solid var(--color-orange);
  }

  @media (max-width: 380px) {
    .mcta__btn span { display: none; }
    .mcta__btn { gap: 0; padding: 0.85rem; }
  }
</style>

<style is:global>
  /* Reserve space at the bottom of mobile pages so content isn't hidden behind the bar */
  @media (max-width: 720px) {
    body {
      padding-bottom: calc(72px + env(safe-area-inset-bottom));
    }
  }
</style>
