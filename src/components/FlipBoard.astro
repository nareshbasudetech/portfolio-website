---
interface Row {
  destination: string;
  status: 'BOARDING' | 'DEPLOYED' | 'IN-FLIGHT';
  discipline: 'DEV' | 'DESIGN' | 'GROWTH';
  time: string;
  href: string;
}

const rows: Row[] = [
  { destination: 'THE WHOLE FUNNEL',      status: 'BOARDING',  discipline: 'GROWTH', time: 'NOW',     href: '/contact' },
  { destination: 'GROWTH · 20+ BRANDS',   status: 'IN-FLIGHT', discipline: 'GROWTH', time: 'ONGOING', href: '/projects/growth-marketing-engagements' },
  { destination: 'NARESH-CRM · LEADS',    status: 'IN-FLIGHT', discipline: 'DEV',    time: '2026',    href: '/projects/naresh-crm-lead-management' },
  { destination: 'WHATSAPP · LEAD BOT',   status: 'DEPLOYED',  discipline: 'DEV',    time: '2026',    href: '/projects/whatsapp-leadbot' },
  { destination: 'NURSINGPATHSHALA',      status: 'DEPLOYED',  discipline: 'DEV',    time: '2026',    href: '/projects/nursingpathshala-app' },
  { destination: 'ABS + NGI · EDU',       status: 'DEPLOYED',  discipline: 'DEV',    time: '2026',    href: '/projects/education-platforms' },
  { destination: 'BOOKWITHTEACHERS',      status: 'DEPLOYED',  discipline: 'DEV',    time: '2026',    href: '/projects/bookwithteachers' },
  { destination: 'NIP COLLEGE · REBUILD', status: 'DEPLOYED',  discipline: 'DEV',    time: '2026',    href: '/projects/nipcollege-rebuild' },
];
---

<section class="board" aria-label="Departures board — selected projects">
  <div class="board__frame">
    <header class="board__top">
      <span class="board__brand">
        <span class="dot" aria-hidden="true"></span>
        <span data-flap>NARESH · BASUDE</span>
      </span>
      <span class="board__title" data-flap>DEPARTURES · 2026</span>
      <span class="board__clock" data-flap data-clock>00:00:00</span>
    </header>

    <div class="board__head" aria-hidden="true">
      <span data-flap>DESTINATION</span>
      <span data-flap>STATUS</span>
      <span data-flap>DISCIPLINE</span>
      <span data-flap>TIME</span>
    </div>

    <ol class="board__rows" role="list">
      {rows.map((r, i) => (
        <li class="row" style={`--i:${i}`} data-status={r.status} data-disc={r.discipline}>
          <a href={r.href} class="row__a">
            <span class="row__dest" data-flap>{r.destination}</span>
            <span class="row__stat" data-flap>{r.status}</span>
            <span class="row__disc" data-flap>{r.discipline}</span>
            <span class="row__time" data-flap>{r.time}</span>
            <span class="row__arr" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>

<script is:inline>
  (() => {
    const ALPHA = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';

    function flap(el, target, dur) {
      if (!target) return;
      const start = performance.now();
      const finalChars = [...target];
      const skip = (c) => c === ' ' || c === '·' || c === '/' || c === ':' || c === '<' || c === '>' || c === '✦' || c === '.';

      function tick(now) {
        const t = Math.min((now - start) / dur, 1);
        const settled = Math.floor(t * finalChars.length);
        let out = '';
        for (let i = 0; i < finalChars.length; i++) {
          if (i < settled || skip(finalChars[i])) {
            out += finalChars[i];
          } else {
            out += ALPHA[(Math.random() * ALPHA.length) | 0];
          }
        }
        el.textContent = out;
        if (t < 1) requestAnimationFrame(tick);
        else el.textContent = target;
      }
      requestAnimationFrame(tick);
    }

    function flapAllStaggered() {
      // Stagger by row, not all-at-once. Header first, then each row.
      const groups = [
        document.querySelectorAll('.board__top [data-flap], .board__head [data-flap]'),
        ...Array.from(document.querySelectorAll('.row')).map((r) => r.querySelectorAll('[data-flap]')),
      ];
      let delay = 0;
      groups.forEach((group) => {
        group.forEach((el, i) => {
          const target = el.dataset.flapTarget || el.textContent;
          el.dataset.flapTarget = target;
          setTimeout(() => flap(el, target, 650 + ((i * 47) % 250)), delay + i * 25);
        });
        delay += 180;
      });
    }

    function pickFlapper() {
      const all = document.querySelectorAll('.row [data-flap]');
      if (!all.length) return;
      const el = all[(Math.random() * all.length) | 0];
      const target = el.dataset.flapTarget || el.textContent;
      flap(el, target, 550);
    }

    function startClock() {
      const el = document.querySelector('[data-clock]');
      if (!el) return;
      const tick = () => {
        const d = new Date();
        const pad = (n) => String(n).padStart(2, '0');
        const txt = `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
        el.dataset.flapTarget = txt;
        if (d.getSeconds() % 10 === 0) flap(el, txt, 320);
        else el.textContent = txt;
      };
      tick();
      setInterval(tick, 1000);
    }

    let cycleTimer;
    function start() {
      flapAllStaggered();
      clearInterval(cycleTimer);
      cycleTimer = setInterval(pickFlapper, 4500);
      startClock();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', start);
    } else {
      start();
    }
    document.addEventListener('astro:page-load', start);
  })();
</script>

<style>
  .board {
    --board-green: #5af28b;
    position: relative;
    width: 100%;
  }

  .board__frame {
    position: relative;
    border: 1px solid color-mix(in oklab, var(--color-ivory) 12%, transparent);
    border-radius: var(--radius-md);
    background: var(--color-ink-2);
    padding: clamp(1rem, 2vw, 1.75rem) clamp(1rem, 2vw, 2rem);
    overflow: hidden;
  }

  /* Top bar */
  .board__top {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 0.4rem;
    border-bottom: 1px solid var(--grid-line);
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .board__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-orange);
  }
  .board__title { text-align: center; opacity: 0.7; }
  .board__clock { text-align: right; color: var(--color-orange); }

  /* Column headers */
  .board__head {
    display: grid;
    grid-template-columns: minmax(0, 2fr) 130px 110px 100px;
    gap: 1.5rem;
    padding: 0.5rem 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-mute);
    border-bottom: 1px solid var(--grid-line);
  }

  /* Rows */
  .board__rows { list-style: none; padding: 0; margin: 0; }
  .row {
    border-bottom: 1px solid color-mix(in oklab, var(--color-ivory) 5%, transparent);
  }
  .row:last-child { border-bottom: 0; }

  .row__a {
    display: grid;
    grid-template-columns: minmax(0, 2fr) 130px 110px 100px 24px;
    gap: 1.5rem;
    align-items: center;
    padding: 0.95rem 0.4rem;
    font-family: var(--font-mono);
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    letter-spacing: 0.04em;
    color: var(--color-ivory);
    transition: background 240ms, padding 280ms var(--ease-out-expo);
  }
  .row__a:hover, .row__a:focus-visible {
    background: linear-gradient(90deg, color-mix(in oklab, var(--color-orange) 10%, transparent), transparent 70%);
    padding-left: 1.2rem;
    outline: 2px solid color-mix(in oklab, var(--color-orange) 40%, transparent);
    outline-offset: -2px;
    border-radius: 4px;
  }
  .row__a:hover .row__arr, .row__a:focus-visible .row__arr {
    transform: translateX(0);
    opacity: 1;
  }

  .row__dest  { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .row__stat  { font-size: 0.85em; }
  .row__disc  { font-size: 0.78em; opacity: 0.85; }
  .row__time  { font-size: 0.85em; opacity: 0.75; text-align: right; }
  .row__arr   {
    color: var(--color-orange);
    transform: translateX(-6px);
    opacity: 0;
    transition: transform 280ms var(--ease-out-expo), opacity 200ms;
    font-size: 1.05em;
  }

  /* Status colors */
  .row[data-status='BOARDING'] .row__stat {
    color: var(--color-orange);
    animation: soft-blink 2.4s ease-in-out infinite;
  }
  .row[data-status='BOARDING'] .row__dest { color: var(--color-ivory); font-weight: 500; }
  .row[data-status='IN-FLIGHT'] .row__stat { color: var(--color-violet); }
  .row[data-status='DEPLOYED']  .row__stat { color: var(--board-green); opacity: 0.8; }

  /* Discipline tags */
  .row[data-disc='DEV']    .row__disc { color: var(--color-orange); }
  .row[data-disc='DESIGN'] .row__disc { color: var(--color-violet); }
  .row[data-disc='GROWTH'] .row__disc { color: var(--color-ivory); }

  @keyframes soft-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.55; }
  }

  /* Responsive */
  @media (max-width: 820px) {
    .board__head, .row__a {
      grid-template-columns: minmax(0, 1.6fr) 100px 90px;
      gap: 0.8rem;
    }
    .board__head > :nth-child(3), /* hide DISCIPLINE header */
    .row__disc { display: none; }
    .row__arr { display: none; }
    .row__a { font-size: 0.9rem; padding: 0.75rem 0.3rem; }
  }
  @media (max-width: 540px) {
    .board__head, .row__a {
      grid-template-columns: minmax(0, 1.4fr) 80px;
    }
    .board__head > :nth-child(2), /* hide STATUS header */
    .row__time { display: none; }
    .board__top { grid-template-columns: 1fr 1fr; gap: 0.5rem; }
    .board__title { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .row[data-status='BOARDING'] .row__stat { animation: none; }
  }
</style>
