---
import { SITE, NAV, CONTACT } from '~/consts';
const year = new Date().getFullYear();
---

<footer class="ftr">
  <div class="ftr__inner shell">
    <div class="ftr__top">
      <a href={`mailto:${SITE.email}`} class="ftr__big">
        Let's make it <em>move</em>.<span aria-hidden="true"> ↗</span>
      </a>
      <p class="t-lede">
        Got a project? One email is enough. {SITE.availability.toLowerCase()} — replies inside 24 hours.
      </p>
    </div>

    <div class="ftr__grid">
      <div>
        <h4 class="t-mono-sm">Site</h4>
        <ul>
          {NAV.map(({ label, href }) => <li><a href={href}>{label}</a></li>)}
          <li><a href="/rss.xml">RSS</a></li>
          <li><a href="/privacy">Privacy</a></li>
        </ul>
      </div>
      <div>
        <h4 class="t-mono-sm">Local — MMR</h4>
        <ul>
          <li><a href="/thane">Thane</a></li>
          <li><a href="/mumbai">Mumbai</a></li>
          <li><a href="/navi-mumbai">Navi Mumbai</a></li>
          <li><a href="/kalyan-bhiwandi">Kalyan-Bhiwandi</a></li>
          <li><a href="/dombivli">Dombivli</a></li>
          <li><a href="/mira-bhayandar">Mira-Bhayandar</a></li>
          <li><a href="/vasai-virar">Vasai-Virar</a></li>
          <li><a href="/panvel">Panvel</a></li>
          <li><a href="/ulhasnagar">Ulhasnagar</a></li>
          <li><a href="/ambernath-badlapur">Ambernath-Badlapur</a></li>
          <li><a href="/cities" style="color: var(--color-orange);">All cities ↗</a></li>
        </ul>
      </div>
      <div>
        <h4 class="t-mono-sm">Reach</h4>
        <ul>
          <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
          <li><a href={`tel:${CONTACT.phone}`}>{CONTACT.phoneDisplay}</a></li>
          <li><a href={`https://wa.me/${CONTACT.whatsapp}`} target="_blank" rel="noopener">WhatsApp ↗</a></li>
          {CONTACT.linkedin && <li><a href={CONTACT.linkedin} target="_blank" rel="noopener">LinkedIn ↗</a></li>}
          <li><span>India → Remote</span></li>
        </ul>
      </div>
      <div>
        <h4 class="t-mono-sm">Disciplines</h4>
        <ul>
          <li>Development</li>
          <li>Design</li>
          <li>Marketing</li>
        </ul>
      </div>
      <div>
        <h4 class="t-mono-sm">Colophon</h4>
        <ul>
          <li>Astro · TypeScript · Tailwind v4</li>
          <li>General Sans · Inter · JetBrains Mono</li>
          <li>Volume 02 · {year}</li>
        </ul>
      </div>
    </div>

    <div class="ftr__bot">
      <span><b>{SITE.name}</b> &copy; {year} — All rights reserved</span>
      <span class="ftr__sig">[ N — {year} ]</span>
      <span><a href={SITE.url}>{SITE.domain}</a></span>
    </div>
  </div>
</footer>

<style>
  .ftr {
    border-top: 1px solid var(--grid-line);
    background: linear-gradient(180deg, transparent, var(--color-ink-2));
    margin-top: 8rem;
  }
  .ftr__inner { padding-block: 6rem 2rem; }
  .ftr__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 4rem;
    align-items: end;
    padding-bottom: 5rem;
    border-bottom: 1px solid var(--grid-line);
  }
  .ftr__big {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 8vw, 6.5rem);
    letter-spacing: -0.03em;
    line-height: 0.95;
    transition: color 250ms;
  }
  .ftr__big:hover { color: var(--color-orange); }
  .ftr__big em {
    color: var(--color-orange);
    font-style: italic;
  }
  .ftr__grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--grid-line);
  }
  .ftr__grid h4 { margin-bottom: 1rem; }
  .ftr__grid ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: var(--color-ivory-dim);
  }
  .ftr__grid a:hover { color: var(--color-orange); }
  .ftr__bot {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    opacity: 0.55;
  }
  .ftr__sig { color: var(--color-orange); }
  .ftr__bot > :last-child { text-align: right; }

  @media (max-width: 1024px) {
    .ftr__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 820px) {
    .ftr__top { grid-template-columns: 1fr; gap: 1.5rem; padding-bottom: 3rem; }
    .ftr__grid { grid-template-columns: repeat(2, 1fr); }
    .ftr__bot { grid-template-columns: 1fr; text-align: left; }
    .ftr__bot > :last-child { text-align: left; }
  }
</style>
