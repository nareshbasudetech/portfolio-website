---
import { NAV, SITE } from '~/consts';

const path = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="nav">
  <div class="nav__inner shell">
    <a href="/" class="nav__brand" aria-label={`${SITE.name} — Home`}>
      <span class="nav__mark" aria-hidden="true">N</span>
      <span class="nav__name">{SITE.name}</span>
      <span class="nav__yr" aria-hidden="true">/ 2026</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {NAV.map(({ num, label, href }) => (
        <a href={href} aria-current={isActive(href) ? 'page' : undefined}>
          <span class="num" aria-hidden="true">{num}</span>
          <span class="lbl">{label}</span>
        </a>
      ))}
    </nav>

    <a href={`mailto:${SITE.email}`} class="nav__cta">
      <span>Start a project</span>
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px) saturate(160%);
    background: color-mix(in oklab, var(--color-ink) 78%, transparent);
    border-bottom: 1px solid var(--grid-line);
  }
  .nav__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
    padding-block: 0.9rem;
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .nav__mark {
    display: grid;
    place-items: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 0.45rem;
    background: var(--color-ivory);
    color: var(--color-ink);
    font-weight: 700;
    font-size: 0.95rem;
    position: relative;
  }
  .nav__mark::after {
    content: '';
    position: absolute;
    top: 0.18rem;
    right: 0.18rem;
    width: 0.32rem;
    height: 0.32rem;
    border-radius: 999px;
    background: var(--color-orange);
  }
  .nav__yr { font-family: var(--font-mono); font-size: 0.7rem; opacity: 0.5; font-weight: 400; }
  .nav__links {
    display: flex;
    justify-content: center;
    gap: 2rem;
    font-family: var(--font-sans);
    font-size: 0.92rem;
  }
  .nav__links a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    opacity: 0.7;
    transition: opacity 180ms;
    position: relative;
  }
  .nav__links a:hover, .nav__links a[aria-current='page'] { opacity: 1; }
  .nav__links a[aria-current='page']::before {
    content: '';
    position: absolute;
    left: -0.85rem;
    top: 50%;
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--color-orange);
    transform: translateY(-50%);
  }
  .num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    opacity: 0.55;
  }
  .nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--color-ivory) 22%, transparent);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 200ms, color 200ms, border-color 200ms;
  }
  .nav__cta:hover {
    background: var(--color-orange);
    color: var(--color-ink);
    border-color: var(--color-orange);
  }

  @media (max-width: 820px) {
    .nav__inner { grid-template-columns: auto 1fr auto; gap: 1rem; }
    .nav__yr, .num { display: none; }
    .nav__links { gap: 1.1rem; }
    .nav__cta span:first-child { display: none; }
    .nav__cta { padding: 0.55rem 0.7rem; }
  }
  @media (max-width: 520px) {
    .nav__name { display: none; }
  }
</style>
