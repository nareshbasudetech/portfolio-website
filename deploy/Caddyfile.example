# Caddyfile for nareshbasude.in (portfolio)
#
# Install location: /etc/caddy/Caddyfile
# After editing: sudo systemctl reload caddy
#
# Caddy auto-provisions Let's Encrypt SSL — no certbot needed.
# Make sure ports 80 + 443 are open in your VPS firewall (ufw allow 80,443/tcp).
#
# ⚠ IMPORTANT — preserve shruti.nareshbasude.in
# If shruti.nareshbasude.in is currently served by another web server config
# (nginx site, separate Caddyfile import, Docker container, etc.) — LEAVE IT
# ALONE. This file only configures nareshbasude.in (apex + www).
#
# If you're migrating away from nginx to Caddy, you must also bring shruti's
# config into this Caddyfile or as an `import` directive. There's a stub block
# at the bottom of this file for that — fill it in with whatever currently
# serves shruti, then delete the bot-related config in nginx/Apache/wherever.

# ─── PORTFOLIO (apex + www) ──────────────────────────────────────────
nareshbasude.in, www.nareshbasude.in {
    # Document root — must match VPS_PATH in GitHub Actions secrets
    root * /var/www/portfolio

    # Compress responses
    encode zstd gzip

    # Security headers (matches what was in .htaccess before)
    header {
        Strict-Transport-Security      "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options         nosniff
        X-Frame-Options                SAMEORIGIN
        Referrer-Policy                strict-origin-when-cross-origin
        Permissions-Policy             "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # Cache static assets aggressively
    @assets {
        path *.css *.js *.svg *.png *.jpg *.jpeg *.webp *.avif *.ico *.woff *.woff2 *.ttf
    }
    header @assets Cache-Control "public, max-age=31536000, immutable"

    # HTML — short cache to allow quick updates
    @html {
        path *.html
    }
    header @html Cache-Control "public, max-age=300, must-revalidate"

    # Sitemap / robots / llms — even shorter
    @meta {
        path /sitemap*.xml /robots.txt /llms.txt /rss.xml /humans.txt
    }
    header @meta Cache-Control "public, max-age=600"

    # Astro's trailingSlash: 'never' — strip trailing slashes (except root)
    @trailing_slash {
        path_regexp ts ^(/.+)/$
    }
    redir @trailing_slash {re.ts.1} 301

    # Force www → apex
    @www {
        host www.nareshbasude.in
    }
    redir @www https://nareshbasude.in{uri} 301

    # SPA-style fallback for clean URLs (e.g., /thane → /thane/index.html)
    try_files {path} {path}/index.html {path}.html /404.html

    # Serve files
    file_server

    # 404 page
    handle_errors {
        @404 expression `{err.status_code} == 404`
        rewrite @404 /404.html
        file_server
    }

    # Access log (rotate weekly, keep 4)
    log {
        output file /var/log/caddy/portfolio.access.log {
            roll_size 50mb
            roll_keep 4
        }
        format console
    }
}

# ─── SHRUTI SUBDOMAIN (preserve existing) ────────────────────────────
# Only fill this in if Caddy will be the web server for shruti.nareshbasude.in
# too. If shruti is already running on nginx/Apache/Docker and you're keeping
# that — leave this block commented out, and make sure your migration steps
# don't disable whatever is serving shruti today.
#
# Find out what currently serves shruti:
#   grep -rl "shruti" /etc/nginx /etc/caddy /etc/apache2 2>/dev/null
#   curl -I https://shruti.nareshbasude.in
#
# Common patterns — uncomment + adapt whichever applies:
#
# # Static files:
# shruti.nareshbasude.in {
#     root * /var/www/shruti
#     encode zstd gzip
#     file_server
#     header Strict-Transport-Security "max-age=31536000; includeSubDomains"
# }
#
# # Reverse-proxy to a Node/Python app on localhost:
# shruti.nareshbasude.in {
#     reverse_proxy localhost:3000
#     encode zstd gzip
#     header Strict-Transport-Security "max-age=31536000; includeSubDomains"
# }
#
# # WordPress / PHP-FPM:
# shruti.nareshbasude.in {
#     root * /var/www/shruti
#     php_fastcgi unix//run/php/php8.2-fpm.sock
#     file_server
# }
